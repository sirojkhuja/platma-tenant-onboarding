# App
PORT=3000
NODE_ENV=development

# Database (local docker-compose default)
# DATABASE_DRIVER=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=platma
DATABASE_PASSWORD=platma
DATABASE_NAME=platma

# Keycloak (local docker-compose default)
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=platma

# Dev-only admin user auth (token realm is usually master)
KEYCLOAK_TOKEN_GRANT_TYPE=password
KEYCLOAK_TOKEN_REALM=master
KEYCLOAK_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Manifests
MANIFEST_OUTPUT_MODE=response
MANIFEST_OUTPUT_DIR=./manifests
K8S_NAMESPACE=default

# Kubernetes runtime
K8S_DEPLOY_MODE=manifest
# K8S_KUBECONFIG_PATH=/home/user/.kube/config
K8S_CREATE_NAMESPACE=true
# K8S_PUBLIC_HOST=192.168.32.3
K8S_ROLLOUT_TIMEOUT_MS=180000
K8S_ROLLOUT_POLL_INTERVAL_MS=2000

# Node-RED workload
NODE_RED_IMAGE=nodered/node-red:3.1.0
NODE_RED_EDITOR_USERNAME=admin
NODE_RED_PASSWORD_SEED=dev-only-change-me-node-red-password-seed
NODE_RED_PASSWORD_LENGTH=24
NODE_RED_STORAGE_SIZE=1Gi
# NODE_RED_STORAGE_CLASS=standard
# Use NodePort for stable local access without kubectl port-forward.
NODE_RED_SERVICE_TYPE=ClusterIP
NODE_RED_ENABLE_INGRESS=false
# NODE_RED_BASE_DOMAIN=apps.localtest.me
# NODE_RED_INGRESS_CLASS_NAME=nginx
NODE_RED_CPU_REQUEST=100m
NODE_RED_CPU_LIMIT=500m
NODE_RED_MEMORY_REQUEST=256Mi
NODE_RED_MEMORY_LIMIT=512Mi

# HTTP resilience
KEYCLOAK_HTTP_TIMEOUT_MS=5000
KEYCLOAK_HTTP_RETRY_COUNT=2
